{
  "name": "bluethub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "web:dev": "turbo dev --filter=@bluethub/web",
    "landing:dev": "turbo dev --filter=@bluethub/landing",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
     "@bluethub/eslint-config": "workspace:*",
    "prettier": "^3.7.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.8",
      "csstype": "3.2.3"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
