{
  "name": "@bluethub/ui-kit",
  "version": "1.0.0",
  "private": true,
  "description": "Shared UI components and utilities for bluethub monorepo",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
